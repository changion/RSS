{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "情报订阅站",
  "version": "1.0.0",
  "identifier": "com.intel-hub.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "",
    "frontendDist": "../../web/out"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "情报订阅站",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3000 http://localhost:3001; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  }
}
