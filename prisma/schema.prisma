// Prisma Schema — intel-hub Phase 1 + Phase 2
// SQLite 数据库（不支持原生枚举，使用 String 注释说明取值范围）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Phase 1 Models ──────────────────────────────────────────────────────────

model Channel {
  id                String   @id @default(uuid())
  name              String
  description       String   @default("")
  /// "PUBLIC" | "PRIVATE"
  type              String   @default("PUBLIC")
  /// JSON 字符串，存储采集规则
  collectRule       String   @default("{}")
  collectFrequency  String   @default("0 2 * * *")
  defaultPrompt     String?
  /// "ACTIVE" | "PAUSED" | "DRAFT"
  status            String   @default("DRAFT")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dailyReports      DailyReport[]
  subscriptions     Subscription[]

  @@map("channels")
}

model DailyReport {
  id               String   @id @default(uuid())
  channelId        String
  /// 关联用户（null 表示全局报告，非空表示用户专属报告）
  userId           String?
  reportDate       DateTime
  /// JSON 字符串，原始采集条目数组
  rawItems         String   @default("[]")
  processedContent String?
  promptUsed       String?
  itemCount        Int      @default(0)
  aiModel          String?
  contentHash      String?
  processingMs     Int?
  createdAt        DateTime @default(now())

  channel          Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportDate])
  @@index([contentHash])
  @@index([userId])
  @@map("daily_reports")
}

model PushLog {
  id          String    @id @default(uuid())
  /// 关联用户（null 表示全局推送）
  userId      String?
  reportDate  DateTime
  /// "FEISHU" | "EMAIL" | "WEB"
  channel     String    @default("FEISHU")
  /// "PENDING" | "SENT" | "FAILED" | "SKIPPED"
  status      String    @default("PENDING")
  sentAt      DateTime?
  errorMsg    String?
  createdAt   DateTime  @default(now())

  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportDate])
  @@index([status])
  @@index([userId])
  @@map("push_logs")
}

// ─── Phase 2 Models ──────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  /// "ADMIN" | "USER" | "INVITED"
  role          String   @default("USER")
  displayName   String?
  feishuWebhook String?
  emailAddress  String?
  emailNotify   Boolean  @default(false)
  /// "ACTIVE" | "SUSPENDED"
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions   Subscription[]
  dailyReports    DailyReport[]
  pushLogs        PushLog[]
  channelRequests ChannelRequest[]

  @@map("users")
}

model Subscription {
  id           String    @id @default(uuid())
  userId       String
  channelId    String
  /// "PENDING" | "REVIEWING" | "ACTIVE" | "REJECTED" | "PAUSED"
  status       String    @default("PENDING")
  applyReason  String
  customPrompt String?
  /// "PENDING_REVIEW" | "APPROVED" | "REJECTED"
  promptStatus String    @default("PENDING_REVIEW")
  adminNote    String?
  activatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
  @@index([channelId])
  @@index([status])
  @@map("subscriptions")
}

// ─── Phase 3 Models ──────────────────────────────────────────────────────────

model ChannelRequest {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String
  /// "RSS" | "APK" | "WEBSITE" | "RANKING" | "AD" | "SOCIAL" | "OTHER"
  contentType  String
  sourceHint   String?
  customPrompt String?
  /// "PENDING" | "REVIEWING" | "APPROVED" | "REJECTED"
  status       String   @default("PENDING")
  adminNote    String?
  /// 审批通过后关联创建的频道
  channelId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("channel_requests")
}
